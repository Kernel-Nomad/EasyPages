# EasyPages — copy to .env and fill in values
# / Copia a .env y rellena los valores: cp .env.example .env
#
# Minimum required (app will not start without these):
# / Mínimo obligatorio:
#   CF_API_TOKEN, CF_ACCOUNT_ID, AUTH_USER, AUTH_PASS
#
# Optional: SESSION_SECRET, SESSION_COOKIE_SECURE, NODE_ENV (see README Notes)
# / Opcionales: SESSION_SECRET, SESSION_COOKIE_SECURE, NODE_ENV (véase Notas en README)

# Runtime
PORT=8002
# NODE_ENV=production

# Cloudflare
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=xxxxx
CF_ACCOUNT_ID=xxxxx

# Dashboard auth
AUTH_USER=admin
AUTH_PASS=password123

# Secreto de sesión (express-session). Con NODE_ENV=production:
# - Obligatorio salvo que uses Docker Compose tal cual: el compose define EASYPAGES_DATA_DIR y monta un volumen;
#   entonces el servidor puede crear .session_secret en ese directorio la primera vez.
# - En desarrollo, si se omite, se genera o reutiliza .session_secret en la raíz del repo.
#SESSION_SECRET=2gcs1br2kf8dasjk8

# Cookie de sesión Secure (opcional). true|false; si se omite, en production es true y en el resto false.
# Pon SESSION_COOKIE_SECURE=false si sirves EasyPages solo por HTTP en un entorno marcado como production.
#SESSION_COOKIE_SECURE=true
