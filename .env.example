# 1) Required
CF_API_TOKEN=xxxxx
CF_ACCOUNT_ID=xxxxx
AUTH_USER=admin
AUTH_PASS=your-password-here   # Recommended: bcrypt hash of your password.

# 2) Recommended
# SESSION_SECRET=...   # Override if you manage secrets externally or run multiple nodes without a shared data volume.

# 3) Optional
# PORT=8002
# SESSION_COOKIE_SECURE=false
# TRUST_PROXY=false          # Optional: set when Node is exposed without a trusted reverse proxy (default is 1 hop). See CONTRIBUTING.md.
