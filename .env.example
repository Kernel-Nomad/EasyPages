# 1) Required
CF_API_TOKEN=xxxxx
CF_ACCOUNT_ID=xxxxx
AUTH_USER=admin
AUTH_PASS=password123

# 2) Recommended. If omitted, the server picks a random secret at startup (sessions invalid after restart; see CONTRIBUTING.md).
# SESSION_SECRET=your-secret-here # Generate: openssl rand -hex 32

# 3) Optional
# PORT=8002
# SESSION_COOKIE_SECURE=false
