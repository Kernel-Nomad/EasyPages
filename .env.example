# EasyPages — copy to .env and fill in values: cp .env.example .env
#
# Minimum required (app will not start without these):
#   CF_API_TOKEN, CF_ACCOUNT_ID, AUTH_USER, AUTH_PASS
#
# Optional: SESSION_SECRET, SESSION_COOKIE_SECURE, NODE_ENV (see README Notes)

# Runtime
PORT=8002
# NODE_ENV=production

# Cloudflare
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=xxxxx
CF_ACCOUNT_ID=xxxxx

# Dashboard auth
AUTH_USER=admin
AUTH_PASS=password123

# Session secret (express-session). With NODE_ENV=production:
# - Required unless you use Docker Compose as documented: compose sets EASYPAGES_DATA_DIR and mounts a volume;
#   then the server can create .session_secret in that directory on first run.
# - In development, if omitted, .session_secret is generated or reused at the repo root.
#SESSION_SECRET=2gcs1br2kf8dasjk8

# Session cookie Secure flag (optional). true|false; if omitted, true in production and false otherwise.
# Set SESSION_COOKIE_SECURE=false if you serve EasyPages over HTTP only in an environment marked as production.
#SESSION_COOKIE_SECURE=true
